#!/usr/bin/env bash
# Foreman CLI — thin wrapper around the HTTP API
# Install adds this to PATH via symlink

set -euo pipefail

FOREMAN_URL="${FOREMAN_URL:-http://127.0.0.1:7374}"
API="$FOREMAN_URL/api"

usage() {
  cat << 'EOF'
Foreman — autonomous operating system

Usage: foreman <command> [args]

Commands:
  status           Show portfolio status (goals, sessions, recent decisions)
  setup            Re-run the Foreman onboarding wizard
  replay-policies  List replay-evaluable dispatch policies
  replay-summary   Show replay dataset summary (optional: --limit N --project foo --skill /evolve)
  replay-examples  Show replay examples (optional: --limit N --project foo --skill /evolve)
  replay-evaluate  Evaluate a dispatch policy on replay data against a baseline
  replay-promote   Evaluate a policy and optionally apply it when promotion passes
  policy           Show or set the active dispatch policy
  telemetry-import Import/backfill telemetry from local traces and session artifacts
  goals            List active goals
  goal <intent>    Create a new goal
  dispatch <task>  Dispatch a task (optional: --skill /evolve --workspace ~/code/foo)
  sessions         List active sessions
  watch            Watch all sessions live (tmux grid)
  decisions [N]    Show last N decisions (default: 10)
  plans            List strategic plans
  plan             Generate new strategic plans
  confidence       Show confidence levels
  learn            Trigger learning loop
  logs             Follow service logs
  restart          Restart the service
  update           Pull latest and restart

EOF
}

json() { curl -sf "$@" | python3 -m json.tool 2>/dev/null || curl -sf "$@"; }

case "${1:-help}" in
  status)
    json "$API/status"
    ;;
  setup)
    shift
    REPO="${FOREMAN_HOME:-$HOME/.foreman}/repo"
    bash "$REPO/install.sh" --configure "$@"
    ;;
  replay-policies)
    json "$API/replay/policies"
    ;;
  replay-summary)
    shift
    LIMIT="250"
    PROJECT=""
    SKILL=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --limit) LIMIT="$2"; shift 2;;
        --project) PROJECT="$2"; shift 2;;
        --skill) SKILL="$2"; shift 2;;
        *) echo "Unknown option: $1"; exit 1;;
      esac
    done
    QUERY="limit=$LIMIT"
    [ -n "$PROJECT" ] && QUERY="$QUERY&project=$PROJECT"
    [ -n "$SKILL" ] && QUERY="$QUERY&skill=$SKILL"
    json "$API/replay/summary?$QUERY"
    ;;
  replay-examples)
    shift
    LIMIT="25"
    PROJECT=""
    SKILL=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --limit) LIMIT="$2"; shift 2;;
        --project) PROJECT="$2"; shift 2;;
        --skill) SKILL="$2"; shift 2;;
        *) echo "Unknown option: $1"; exit 1;;
      esac
    done
    QUERY="limit=$LIMIT"
    [ -n "$PROJECT" ] && QUERY="$QUERY&project=$PROJECT"
    [ -n "$SKILL" ] && QUERY="$QUERY&skill=$SKILL"
    json "$API/replay/examples?$QUERY"
    ;;
  replay-evaluate)
    shift
    LIMIT="50"
    PROJECT=""
    SKILL=""
    POLICY="identity"
    BASELINE=""
    ALLOW_LIVE="false"
    MIN_EXAMPLES=""
    MIN_GOOD_EXAMPLES=""
    MIN_BAD_EXAMPLES=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --limit) LIMIT="$2"; shift 2;;
        --project) PROJECT="$2"; shift 2;;
        --skill) SKILL="$2"; shift 2;;
        --policy) POLICY="$2"; shift 2;;
        --baseline) BASELINE="$2"; shift 2;;
        --min-examples) MIN_EXAMPLES="$2"; shift 2;;
        --min-good) MIN_GOOD_EXAMPLES="$2"; shift 2;;
        --min-bad) MIN_BAD_EXAMPLES="$2"; shift 2;;
        --allow-live) ALLOW_LIVE="true"; shift;;
        *) echo "Unknown option: $1"; exit 1;;
      esac
    done
    QUERY="limit=$LIMIT&policy=$POLICY&allow_live=$ALLOW_LIVE"
    [ -n "$PROJECT" ] && QUERY="$QUERY&project=$PROJECT"
    [ -n "$SKILL" ] && QUERY="$QUERY&skill=$SKILL"
    [ -n "$BASELINE" ] && QUERY="$QUERY&baseline=$BASELINE"
    [ -n "$MIN_EXAMPLES" ] && QUERY="$QUERY&min_examples=$MIN_EXAMPLES"
    [ -n "$MIN_GOOD_EXAMPLES" ] && QUERY="$QUERY&min_good_examples=$MIN_GOOD_EXAMPLES"
    [ -n "$MIN_BAD_EXAMPLES" ] && QUERY="$QUERY&min_bad_examples=$MIN_BAD_EXAMPLES"
    json "$API/replay/evaluate?$QUERY"
    ;;
  replay-promote)
    shift
    POLICY=""
    BASELINE=""
    PROJECT=""
    SKILL=""
    LIMIT="50"
    APPLY="false"
    FORCE="false"
    ALLOW_LIVE="false"
    MIN_EXAMPLES=""
    MIN_GOOD_EXAMPLES=""
    MIN_BAD_EXAMPLES=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --policy) POLICY="$2"; shift 2;;
        --baseline) BASELINE="$2"; shift 2;;
        --project) PROJECT="$2"; shift 2;;
        --skill) SKILL="$2"; shift 2;;
        --limit) LIMIT="$2"; shift 2;;
        --apply) APPLY="true"; shift;;
        --force) FORCE="true"; shift;;
        --allow-live) ALLOW_LIVE="true"; shift;;
        --min-examples) MIN_EXAMPLES="$2"; shift 2;;
        --min-good) MIN_GOOD_EXAMPLES="$2"; shift 2;;
        --min-bad) MIN_BAD_EXAMPLES="$2"; shift 2;;
        *) echo "Unknown option: $1"; exit 1;;
      esac
    done
    [ -z "$POLICY" ] && { echo "--policy is required"; exit 1; }
    BODY="{\"policy\":\"$POLICY\",\"limit\":$LIMIT,\"apply\":$APPLY,\"force\":$FORCE,\"allowLive\":$ALLOW_LIVE"
    [ -n "$BASELINE" ] && BODY="$BODY, \"baseline\":\"$BASELINE\""
    [ -n "$PROJECT" ] && BODY="$BODY, \"project\":\"$PROJECT\""
    [ -n "$SKILL" ] && BODY="$BODY, \"skill\":\"$SKILL\""
    [ -n "$MIN_EXAMPLES" ] && BODY="$BODY, \"minExamples\":$MIN_EXAMPLES"
    [ -n "$MIN_GOOD_EXAMPLES" ] && BODY="$BODY, \"minGoodExamples\":$MIN_GOOD_EXAMPLES"
    [ -n "$MIN_BAD_EXAMPLES" ] && BODY="$BODY, \"minBadExamples\":$MIN_BAD_EXAMPLES"
    BODY="$BODY}"
    curl -sf -X POST "$API/replay/promote" -H 'Content-Type: application/json' -d "$BODY" | python3 -m json.tool
    ;;
  policy)
    shift
    if [[ $# -eq 0 ]]; then
      json "$API/policy/dispatch"
      exit 0
    fi
    POLICY_NAME="$1"
    BODY="{\"policy\":\"$POLICY_NAME\",\"source\":\"manual_override\"}"
    curl -sf -X POST "$API/policy/dispatch" -H 'Content-Type: application/json' -d "$BODY" | python3 -m json.tool
    ;;
  telemetry-import)
    shift
    MAX_AGE_HOURS=""
    TRACE_ROOT=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --hours) MAX_AGE_HOURS="$2"; shift 2;;
        --trace-root) TRACE_ROOT="$2"; shift 2;;
        *) echo "Unknown option: $1"; exit 1;;
      esac
    done
    BODY="{}"
    if [[ -n "$MAX_AGE_HOURS" || -n "$TRACE_ROOT" ]]; then
      BODY="{"
      [[ -n "$MAX_AGE_HOURS" ]] && BODY="$BODY\"maxAgeHours\":$MAX_AGE_HOURS"
      if [[ -n "$TRACE_ROOT" ]]; then
        [[ -n "$MAX_AGE_HOURS" ]] && BODY="$BODY, "
        BODY="$BODY\"traceRoot\":\"$TRACE_ROOT\""
      fi
      BODY="$BODY}"
    fi
    curl -sf -X POST "$API/telemetry/import" -H 'Content-Type: application/json' -d "$BODY" | python3 -m json.tool
    ;;
  goals)
    json "$API/goals"
    ;;
  goal)
    shift
    curl -sf -X POST "$API/goals" -H 'Content-Type: application/json' \
      -d "{\"intent\": \"$*\"}" | python3 -m json.tool
    ;;
  dispatch)
    shift
    SKILL=""
    WORKSPACE=""
    TASK=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --skill) SKILL="$2"; shift 2;;
        --workspace) WORKSPACE="$2"; shift 2;;
        *) TASK="$TASK $1"; shift;;
      esac
    done
    TASK="${TASK# }"
    BODY="{\"task\": \"$TASK\""
    [ -n "$SKILL" ] && BODY="$BODY, \"skill\": \"$SKILL\""
    [ -n "$WORKSPACE" ] && BODY="$BODY, \"workspace\": \"$WORKSPACE\""
    BODY="$BODY}"
    curl -sf -X POST "$API/dispatch" -H 'Content-Type: application/json' -d "$BODY" | python3 -m json.tool
    ;;
  sessions)
    json "$API/sessions"
    ;;
  watch)
    bash "$(dirname "$0")/../scripts/watch.sh"
    ;;
  decisions)
    LIMIT="${2:-10}"
    json "$API/decisions?limit=$LIMIT"
    ;;
  plans)
    json "$API/plans"
    ;;
  plan)
    curl -sf -X POST "$API/plans/generate" -H 'Content-Type: application/json' | python3 -m json.tool
    ;;
  confidence)
    json "$API/confidence"
    ;;
  learn)
    curl -sf -X POST "$API/learn" -H 'Content-Type: application/json' | python3 -m json.tool
    ;;
  logs)
    journalctl --user -u foreman -f --no-pager
    ;;
  restart)
    systemctl --user restart foreman.service
    echo "Foreman restarted"
    ;;
  update)
    REPO="${FOREMAN_HOME:-$HOME/.foreman}/repo"
    cd "$REPO" && git pull --rebase
    systemctl --user restart foreman.service
    echo "Updated and restarted"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac
