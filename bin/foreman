#!/usr/bin/env bash
# Foreman CLI — thin wrapper around the HTTP API
# Install adds this to PATH via symlink

set -euo pipefail

FOREMAN_URL="${FOREMAN_URL:-http://127.0.0.1:7374}"
API="$FOREMAN_URL/api"

usage() {
  cat << 'EOF'
Foreman — autonomous operating system

Usage: foreman <command> [args]

Commands:
  status           Show portfolio status (goals, sessions, recent decisions)
  doctor           Check install health, dependencies, config, and service status
  setup            Re-run the Foreman onboarding wizard
  goals            List active goals
  goal <intent>    Create a new goal
  dispatch <task>  Dispatch a task (optional: --skill /evolve --workspace ~/code/foo)
  sessions         List active sessions
  watch            Watch all sessions live (tmux grid)
  decisions [N]    Show last N decisions (default: 10)
  plans            List strategic plans
  plan             Generate new strategic plans
  confidence       Show confidence levels
  learn            Trigger learning loop
  logs             Follow service logs
  restart          Restart the service
  update           Pull latest and restart

EOF
}

json() { curl -sf "$@" | python3 -m json.tool 2>/dev/null || curl -sf "$@"; }

doctor() {
  local foreman_home="${FOREMAN_HOME:-$HOME/.foreman}"
  local repo="$foreman_home/repo"
  local env_file="$foreman_home/.env"
  local failures=0
  local service_mode="manual"
  local health="offline"
  local budget="20"
  local anthropic="no"
  local openai="no"
  local tangle="no"
  local telegram="no"
  local claude_ready="no"
  local pi_ready="no"

  if [ -f "$env_file" ]; then
    set -a
    . "$env_file" 2>/dev/null || true
    set +a
  fi

  [ -n "${FOREMAN_MAX_DAILY_COST:-}" ] && budget="$FOREMAN_MAX_DAILY_COST"
  [ -n "${ANTHROPIC_API_KEY:-}" ] && anthropic="yes"
  [ -n "${OPENAI_API_KEY:-}" ] && openai="yes"
  [ -n "${TANGLE_API_KEY:-}" ] && tangle="yes"
  [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && telegram="yes"

  if command -v claude >/dev/null 2>&1 && command -v tmux >/dev/null 2>&1; then
    claude_ready="yes"
  fi
  if [ -d "$HOME/.pi/agent" ]; then
    pi_ready="yes"
  fi

  if curl -sf "$API/health" >/dev/null 2>&1; then
    health="ok"
  fi

  if command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1; then
    if systemctl --user is-enabled foreman.service >/dev/null 2>&1; then
      service_mode="enabled"
    else
      service_mode="disabled"
    fi
  fi

  for cmd in node npm git; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "FAIL  missing dependency: $cmd"
      failures=$((failures + 1))
    fi
  done

  [ -d "$repo/.git" ] || { echo "FAIL  missing Foreman repo at $repo"; failures=$((failures + 1)); }
  [ -f "$env_file" ] || { echo "FAIL  missing config file at $env_file"; failures=$((failures + 1)); }

  if [ "$service_mode" = "enabled" ] && [ "$health" != "ok" ]; then
    echo "FAIL  service is enabled but health check failed at $FOREMAN_URL/api/health"
    failures=$((failures + 1))
  fi

  echo "Foreman doctor"
  echo "  Home                $foreman_home"
  echo "  Repo                $repo"
  echo "  Service URL         $FOREMAN_URL"
  echo "  Health              $health"
  echo "  Service mode        $service_mode"
  echo "  Daily budget        \$$budget"
  echo "  Claude dispatch     $claude_ready"
  echo "  Pi detected         $pi_ready"
  echo "  Anthropic key       $anthropic"
  echo "  OpenAI key          $openai"
  echo "  Tangle key          $tangle"
  echo "  Telegram configured $telegram"

  if [ "$failures" -gt 0 ]; then
    echo ""
    echo "Doctor found $failures issue(s)."
    exit 1
  fi

  echo ""
  echo "Doctor passed."
}

case "${1:-help}" in
  status)
    json "$API/status"
    ;;
  doctor)
    doctor
    ;;
  setup)
    shift
    REPO="${FOREMAN_HOME:-$HOME/.foreman}/repo"
    bash "$REPO/install.sh" --configure "$@"
    ;;
  goals)
    json "$API/goals"
    ;;
  goal)
    shift
    curl -sf -X POST "$API/goals" -H 'Content-Type: application/json' \
      -d "{\"intent\": \"$*\"}" | python3 -m json.tool
    ;;
  dispatch)
    shift
    SKILL=""
    WORKSPACE=""
    TASK=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --skill) SKILL="$2"; shift 2;;
        --workspace) WORKSPACE="$2"; shift 2;;
        *) TASK="$TASK $1"; shift;;
      esac
    done
    TASK="${TASK# }"
    BODY="{\"task\": \"$TASK\""
    [ -n "$SKILL" ] && BODY="$BODY, \"skill\": \"$SKILL\""
    [ -n "$WORKSPACE" ] && BODY="$BODY, \"workspace\": \"$WORKSPACE\""
    BODY="$BODY}"
    curl -sf -X POST "$API/dispatch" -H 'Content-Type: application/json' -d "$BODY" | python3 -m json.tool
    ;;
  sessions)
    json "$API/sessions"
    ;;
  watch)
    bash "$(dirname "$0")/../scripts/watch.sh"
    ;;
  decisions)
    LIMIT="${2:-10}"
    json "$API/decisions?limit=$LIMIT"
    ;;
  plans)
    json "$API/plans"
    ;;
  plan)
    curl -sf -X POST "$API/plans/generate" -H 'Content-Type: application/json' | python3 -m json.tool
    ;;
  confidence)
    json "$API/confidence"
    ;;
  learn)
    curl -sf -X POST "$API/learn" -H 'Content-Type: application/json' | python3 -m json.tool
    ;;
  logs)
    journalctl --user -u foreman -f --no-pager
    ;;
  restart)
    systemctl --user restart foreman.service
    echo "Foreman restarted"
    ;;
  update)
    REPO="${FOREMAN_HOME:-$HOME/.foreman}/repo"
    cd "$REPO" && git pull --rebase
    systemctl --user restart foreman.service
    echo "Updated and restarted"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac
