{
  "name": "@drew/foreman-repo",
  "version": "0.0.1",
  "private": true,
  "description": "Foreman monorepo.",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "check": "npm run check:types && npm run check:sync",
    "check:types": "npm run check --workspaces --if-present",
    "check:sync": "tsx scripts/check-sync.ts",
    "test": "node --import tsx --test packages/*/src/*.test.ts",
    "foreman:init": "tsx packages/surfaces/src/init-cli.ts init",
    "foreman:daemon": "tsx packages/surfaces/src/foreman-daemon-cli.ts",
    "run": "node --import tsx packages/surfaces/src/run.ts",
    "bootstrap-profile": "tsx packages/surfaces/src/profile-bootstrap-cli.ts",
    "benchmark-traces": "tsx packages/surfaces/src/trace-benchmark-cli.ts",
    "calibrate-judge": "tsx packages/surfaces/src/judge-calibration-cli.ts",
    "observe-environment": "tsx packages/surfaces/src/environment-observe-cli.ts",
    "eval-operator-learning": "tsx packages/surfaces/src/operator-learning-eval-cli.ts",
    "golden-suite": "tsx packages/surfaces/src/golden-suite-cli.ts",
    "optimize-prompts": "tsx packages/surfaces/src/prompt-optimizer-cli.ts",
    "provider-session": "tsx packages/surfaces/src/provider-session-cli.ts",
    "retrieve-traces": "tsx packages/surfaces/src/retrieve-traces-cli.ts",
    "session-run": "tsx packages/surfaces/src/session-run-cli.ts",
    "replay-session": "tsx packages/surfaces/src/session-replay-cli.ts",
    "benchmark-session": "tsx packages/surfaces/src/session-benchmark-cli.ts",
    "replay-browser": "tsx packages/surfaces/src/browser-replay-cli.ts",
    "benchmark-browser": "tsx packages/surfaces/src/browser-benchmark-cli.ts",
    "supervise-browser": "tsx packages/surfaces/src/browser-supervision-cli.ts",
    "session-registry": "tsx packages/surfaces/src/session-registry-cli.ts",
    "supervisor-run": "tsx packages/surfaces/src/supervisor-run-cli.ts",
    "replay-supervisor": "tsx packages/surfaces/src/supervisor-replay-cli.ts",
    "benchmark-supervisor": "tsx packages/surfaces/src/supervisor-benchmark-cli.ts",
    "experiment": "tsx packages/surfaces/src/worktree-experiment-cli.ts",
    "daily-report": "tsx packages/surfaces/src/daily-report-cli.ts",
    "session-index": "tsx packages/surfaces/src/session-index-cli.ts",
    "eval": "tsx packages/surfaces/src/eval-runner-cli.ts",
    "confidence": "tsx packages/surfaces/src/confidence-cli.ts",
    "serve": "tsx packages/surfaces/src/api-server.ts"
  },
  "dependencies": {
    "@ax-llm/ax": "^19.0.17",
    "better-sqlite3": "^12.8.0"
  }
}
